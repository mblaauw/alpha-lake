# Alpha-Lake API Key Configuration
# Copy this file to .env and fill in the keys you need.
# Keys are read from ALPHA_LAKE_<NAME> environment variables.
#
# Required keys fail ingestion with a clear error if missing.
# Optional keys fall back to degraded/keyless mode automatically.

# === Paid / Freemium sources ===

# EODHD — historical data, fundamentals, earnings, news, corp actions
# Signup: https://eodhd.com/register
# Free tier: limited calls/day
ALPHA_LAKE_EODHD_API_KEY=

# Tiingo — bars, fundamentals, news, corp actions
# Signup: https://api.tiingo.com/
# Free tier: yes
ALPHA_LAKE_TIINGO_API_KEY=

# Alpaca — bars
# Signup: https://alpaca.markets/
# Free tier: yes (paper trading)
# Note: Alpaca requires both key ID and secret key
ALPHA_LAKE_ALPACA_API_KEY_ID=
ALPHA_LAKE_ALPACA_API_SECRET_KEY=

# OpenFIGI — FIGI identifier resolution
# Signup: https://www.openfigi.com/
# Free tier: yes
ALPHA_LAKE_OPENFIGI_API_KEY=

# Reddit — social posts / discussion scraping
# Signup: https://www.reddit.com/prefs/apps (create an OAuth app)
# Free tier: yes (OAuth app)
ALPHA_LAKE_REDDIT_API_KEY=

# Quiver Quantitative — congressional trades, alternative data
# Signup: https://www.quiverquant.com/
# Free tier: no (paid subscription required)
ALPHA_LAKE_QUIVER_API_KEY=

# Marketaux — news articles with sentiment scores
# Signup: https://www.marketaux.com/
# Free tier: 100 requests/day
ALPHA_LAKE_MARKETAUX_API_KEY=

# Finnhub — news, sentiment, analyst estimates, insider transactions
# Signup: https://finnhub.io/
# Free tier: 60 requests/min, limited datasets
ALPHA_LAKE_FINNHUB_API_KEY=

# Financial Modeling Prep — economic calendar, analyst ratings
# Signup: https://financialmodelingprep.com/
# Free tier: 250 requests/day
ALPHA_LAKE_FMP_API_KEY=

# === Optional — SEC compliance ===

# Contact email for SEC User-Agent header (recommended for EDGAR access)
# No signup needed; just your email address
# ALPHA_LAKE_SEC_CONTACT_EMAIL=
